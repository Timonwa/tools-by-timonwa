# Environment 
# development | production. Production-only integrations
# APP_ENV=production

# Googe API keys
# Get one at: https://console.cloud.google.com/apis/credentials
# Required
LLM_MODEL="gemini-flash-lite-latest"
GOOGLE_API_KEY=""

# Optional per-tool key overrides.
# GOOGLE_API_KEY_ARTICLE_TO_SEO_META=""
# GOOGLE_API_KEY_ARTICLE_TO_SOCIAL_POST=""

# Upstash Redis
# Get credentials at: https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# IP hashing (production)
# Secret pepper so rate-limit IP hashes aren't brute-force reversible.
# Generate one with: openssl rand -hex 32
# Unset → plain SHA-256 (fine for local/self-host).
IP_HASH_SECRET=""

# Sender API token
# Get one at: https://app.sender.net/settings/tokens
SENDER_API_TOKEN=""