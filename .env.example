# ─────────────────────────────────────────────────────────────
# Core (required)
# ─────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key

# Optional
ADK_DEBUG=false
LLM_MODEL=gemini-2.5-flash

# ─────────────────────────────────────────────────────────────
# Rate limiting (optional) — Upstash Redis
# When both are set, hosted daily limits are enforced server-side
# (per-user + shared pool, both reset at UTC midnight). When blank,
# rate limiting is skipped — fine for local dev and self-hosters.
# Get credentials at: https://console.upstash.com/redis
# ─────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─────────────────────────────────────────────────────────────
# Analytics (optional) — Cloudflare Web Analytics
# Free, cookieless, no consent banner needed.
# Get a token at: https://dash.cloudflare.com/?to=/:account/web-analytics
# Leave blank to disable the beacon entirely.
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLOUDFLARE_ANALYTICS_TOKEN=
