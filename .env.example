# ─────────────────────────────────────────────────────────────
# Environment (optional)
# development | preview | production. Production-only integrations
# (Plausible analytics, Upstash rate limiting) run only when this is
# "production". On Vercel it's derived from VERCEL_ENV automatically;
# leave unset locally (= development).
# ─────────────────────────────────────────────────────────────
# APP_ENV=production

# ─────────────────────────────────────────────────────────────
# Core (required)
# ─────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key
# Optional per-tool key overrides.
GOOGLE_API_KEY_ARTICLE_TO_SEO_META=
GOOGLE_API_KEY_ARTICLE_TO_SOCIAL_POST=

# Optional
ADK_DEBUG=false
LLM_MODEL=gemini-2.5-flash

# ─────────────────────────────────────────────────────────────
# Rate limiting (optional) — Upstash Redis
# When both are set, hosted daily limits are enforced server-side
# (per-user + shared pool, both reset at UTC midnight). When blank,
# rate limiting is skipped — fine for local dev and self-hosters.
# Production only: skipped unless APP_ENV=production.
# Get credentials at: https://console.upstash.com/redis
# ─────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─────────────────────────────────────────────────────────────
# Analytics (optional) — Plausible
# Privacy-friendly, cookieless. No env var needed: the script uses the
# site domain and loads in production only. Add your site in the
# Plausible dashboard: https://plausible.io
# ─────────────────────────────────────────────────────────────
