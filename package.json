	"description": "A growing collection of small, focused, open-source tools by Timonwa.",
	"license": "AGPL-3.0-only",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "eslint .",
		"typecheck": "tsc --noEmit",
		"format": "prettier --write .",
