		"ai": "^7.0.27",
		"clsx": "^2.1.1",
		"dompurify": "^3.4.12",
		"gray-matter": "^4.0.3",
		"lucide-react": "^1.24.0",
		"next": "16.2.10",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"react-simple-code-editor": "^0.14.1",
